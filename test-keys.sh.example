#!/bin/bash
# Example test keys file for integration testing
#
# IMPORTANT: This is an EXAMPLE file containing test keys for local development.
# Copy this file to test-keys.sh and update with your own test keys.
#
# DO NOT commit test-keys.sh to git - it is in .gitignore
#
# Usage:
#   cp test-keys.sh.example test-keys.sh
#   # Edit test-keys.sh with your keys
#   export KEYS_FILE="test-keys.sh"
#   ./scripts/integration-test.sh

# ECDSA private key for commitment signing (64 hex characters)
# IMPORTANT: Replace with your own key! DO NOT use these placeholder values.
#
# For local testing with mock relay, the key must correspond to address:
# 0xf39fd6e51aad88f6f4ce6ab8827279cfffb92266 (Hardhat default account #0)
#
# To generate a new key:
#   - Use Hardhat: npx hardhat node (account #0)
#   - Or use cast: cast wallet new
#   - Or use any Ethereum key generation tool
export ECDSA_PRIVATE_KEY_1="<YOUR_ECDSA_PRIVATE_KEY_HERE>"

# BLS private key for constraint signing (64 hex characters, 32 bytes)
# IMPORTANT: Replace with your own key! DO NOT use this placeholder value.
#
# To generate a new BLS key, use a secure random generator:
#   - openssl rand -hex 32
#   - Or use: head -c 32 /dev/urandom | xxd -p -c 32
export BLS_PRIVATE_KEY_1="<YOUR_BLS_PRIVATE_KEY_HERE>"
