# Environment variables for preconfirmation gateway
# Copy this file to .env and fill in your values

# Database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/preconfirmation_gateway
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/preconfirmation_gateway_test

# ECDSA signing private key (hex string without 0x prefix)
# SECURITY: Generate a new key for production! This is just for development
COMMITTER_PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Logging level
RUST_LOG=info

# Optional: Custom configuration file path
# CONFIG_FILE=config.toml